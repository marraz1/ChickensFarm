# Neon Postgres connection string (unpooled/direct is recommended so `prisma migrate` works reliably).
# Get this from your Neon project dashboard.
DATABASE_URL="postgresql://user:password@ep-example-12345.eu-central-1.aws.neon.tech/chickensfarm?sslmode=require"

# NextAuth / Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Resend (transactional email for password reset). Optional in dev — if unset,
# reset links are logged to the console instead of emailed.
RESEND_API_KEY=""
EMAIL_FROM="ChickensFarm <onboarding@resend.dev>"

# Vercel Blob (Phase 2 — mother hen photos). Not required for Phase 1.
BLOB_READ_WRITE_TOKEN=""
